{
    "name": "cubbit-slideshow",
    "version": "2.0.0",
    "private": true,
    "scripts": {
        "dev": "next dev --turbopack",
        "build": "next build",
        "start": "next start",
        "lint": "next lint",
        "format": "prettier --write .",
        "type-check": "tsc --noEmit",
        "docker:build": "./build-multiarch.sh",
        "docker:build-push": "./build-multiarch.sh -p",
        "helm:package": "helm package ./helm",
        "helm:push": "helm push cubbit-slideshow*.tgz oci://registry.hub.docker.com/cubbit"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.808.0",
        "@aws-sdk/lib-storage": "^3.808.0",
        "better-sqlite3": "^11.7.0",
        "file-type": "^20.5.0",
        "jose": "^6.0.11",
        "next": "^15.3.2",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "sharp": "^0.34.1",
        "uuid": "^11.1.0",
        "winston": "^3.17.0",
        "zod": "^3.24.0"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.12",
        "@types/node": "^22",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@types/uuid": "^10.0.0",
        "eslint": "^9",
        "eslint-config-next": "^15.3.2",
        "prettier": "^3.5.3",
        "tailwindcss": "^4.1.0",
        "@tailwindcss/postcss": "^4.1.0",
        "typescript": "^5"
    }
}
