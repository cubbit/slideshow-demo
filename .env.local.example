# S3 Configuration (MinIO local dev defaults)
S3_BUCKET_NAME=slideshow
S3_PREFIX=
S3_ENDPOINT=http://localhost:9002
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# Upload
MULTIPART_THRESHOLD=5242880
MAX_FILE_SIZE=10485760

# Slideshow
SLIDESHOW_SPEED_S=200
SLIDESHOW_ROWS=3
MIN_COUNT_FOR_MARQUEE=6
CACHE_TTL_S=30

# Auth (optional — if not set, a random password is generated on first run)
# ADMIN_PASSWORD=your-password
# JWT_SECRET=your-jwt-secret

# Webhooks (optional — seeded on first run if no webhooks exist in DB)
# Single webhook shorthand:
# WEBHOOK_URL=https://example.com/webhook
# WEBHOOK_SECRET=your-hmac-secret
# WEBHOOK_NAME=My Webhook
#
# Multiple webhooks (JSON array):
# WEBHOOKS=[{"name":"LED Controller","url":"https://led.example.com/hook","secret":"s3cret","events":{"onUploadProgress":true,"onS3HealthChanged":true}}]

# Logging
LOG_LEVEL=info

# Data directory (SQLite)
DATA_DIR=./data
